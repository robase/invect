{
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": true,
      "decorators": false,
      "dynamicImport": true
    },
    "target": "es2022",
    "loose": false,
    "externalHelpers": false,
    "keepClassNames": false,
    "transform": {
      "react": {
        "runtime": "automatic",
        "development": false,
        "refresh": false
      }
    },
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "module": {
    "type": "es6"
  },
  "minify": false,
  "sourceMaps": false
}