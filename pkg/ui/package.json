{
  "name": "@invect/ui",
  "version": "0.0.12",
  "description": "Complete React components and routes for Invect workflow management",
  "keywords": [
    "components",
    "frontend",
    "invect",
    "react",
    "react-router",
    "typescript",
    "workflow"
  ],
  "homepage": "https://invect.dev",
  "bugs": {
    "url": "https://github.com/robase/invect/issues"
  },
  "license": "MIT",
  "author": "robase <team@invect.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/robase/invect.git",
    "directory": "pkg/ui"
  },
  "style": "dist/index.css",
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "src/**/*"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./demo": {
      "types": "./dist/demo/index.d.ts",
      "import": "./dist/demo.js",
      "default": "./dist/demo.js"
    },
    "./flow-canvas": {
      "types": "./dist/flow-canvas/index.d.ts",
      "import": "./dist/flow-canvas.js",
      "default": "./dist/flow-canvas.js"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "default": "./dist/index.css"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --watch --mode development --emptyOutDir false",
    "dev": "vite build --watch --mode development --emptyOutDir false",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "oxlint --fix",
    "clean": "rm -rf dist",
    "format": "oxfmt",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.11.3",
    "@codemirror/lint": "^6.9.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.8",
    "@fsegurai/codemirror-theme-vscode-dark": "^6.2.4",
    "@fsegurai/codemirror-theme-vscode-light": "^6.2.4",
    "@invect/layouts": "workspace:*",
    "@invect/sdk": "workspace:*",
    "@lezer/highlight": "^1.2.3",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.83.0",
    "@xyflow/react": "^12.9.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "lucide-react": "^0.525.0",
    "nanoid": "^5.1.6",
    "prettier": "^3.8.1",
    "react-hotkeys-hook": "^5.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "react-router": "^7.6.3",
    "react-router-dom": "^7.6.3",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@invect/core": "workspace:*",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^24.0.13",
    "@types/react": "18.3.7",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "postcss-nested": "^7.0.2",
    "tailwindcss": "^4.1.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  }
}
