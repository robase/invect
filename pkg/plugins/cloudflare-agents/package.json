{
  "name": "@invect/cloudflare-agents",
  "version": "0.0.4",
  "description": "Compile Invect flows to Cloudflare Agents & Workflows — deploy visual flows as durable, globally-distributed Workers",
  "license": "MIT",
  "author": "robase <team@invect.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/robase/invect.git",
    "directory": "pkg/plugins/cloudflare-agents"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "main": "dist/backend/index.cjs",
  "module": "dist/backend/index.mjs",
  "types": "dist/backend/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/backend/index.d.mts",
      "import": "./dist/backend/index.mjs",
      "require": "./dist/backend/index.cjs"
    },
    "./compiler": {
      "types": "./dist/compiler/index.d.mts",
      "import": "./dist/compiler/index.mjs",
      "require": "./dist/compiler/index.cjs"
    },
    "./types": {
      "types": "./dist/shared/types.d.mts",
      "import": "./dist/shared/types.mjs",
      "require": "./dist/shared/types.cjs"
    }
  },
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly --outDir dist",
    "build:w": "tsdown --watch",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@invect/core": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "latest",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
