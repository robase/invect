{
  "name": "@invect/mcp",
  "version": "0.0.11",
  "description": "MCP (Model Context Protocol) plugin for Invect — exposes flow building, editing, execution, and debugging as MCP tools for Claude Desktop, VS Code Copilot, and other MCP clients",
  "keywords": [
    "ai-agent",
    "claude",
    "copilot",
    "invect",
    "mcp",
    "model-context-protocol",
    "plugin"
  ],
  "license": "MIT",
  "author": "robase <team@invect.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/robase/invect.git",
    "directory": "pkg/plugins/mcp"
  },
  "bin": {
    "invect-mcp": "./dist/cli/index.mjs"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "main": "dist/backend/index.cjs",
  "module": "dist/backend/index.mjs",
  "types": "dist/backend/index.d.mts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser/index.d.mts",
        "import": "./dist/browser/index.mjs"
      },
      "types": "./dist/backend/index.d.mts",
      "import": "./dist/backend/index.mjs",
      "require": "./dist/backend/index.cjs"
    },
    "./types": {
      "types": "./dist/shared/types.d.mts",
      "import": "./dist/shared/types.mjs",
      "require": "./dist/shared/types.cjs"
    },
    "./cli": {
      "types": "./dist/cli/index.d.mts",
      "import": "./dist/cli/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly --outDir dist",
    "build:w": "tsdown --watch",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --fix"
  },
  "dependencies": {
    "@invect/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@invect/user-auth": ">=0.0.11"
  },
  "peerDependenciesMeta": {
    "@invect/user-auth": {
      "optional": false
    }
  }
}
