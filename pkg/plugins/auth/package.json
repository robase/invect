{
  "name": "@invect/user-auth",
  "version": "0.0.8",
  "description": "Better Auth plugin for Invect — adds user authentication, session management, identity resolution, and auth UI components",
  "keywords": [
    "auth",
    "authentication",
    "better-auth",
    "invect",
    "plugin",
    "workflow"
  ],
  "homepage": "https://invect.dev",
  "bugs": {
    "url": "https://github.com/robase/invect/issues"
  },
  "license": "MIT",
  "author": "robase <team@invect.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/robase/invect.git",
    "directory": "pkg/plugins/auth"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "main": "dist/backend/index.cjs",
  "module": "dist/backend/index.mjs",
  "types": "dist/backend/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/backend/index.d.mts",
      "import": "./dist/backend/index.mjs",
      "require": "./dist/backend/index.cjs"
    },
    "./ui": {
      "types": "./dist/frontend/index.d.mts",
      "import": "./dist/frontend/index.mjs",
      "require": "./dist/frontend/index.cjs"
    },
    "./types": {
      "types": "./dist/shared/types.d.mts",
      "import": "./dist/shared/types.mjs",
      "require": "./dist/shared/types.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly --outDir dist",
    "build:w": "tsdown --watch",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --fix",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@invect/core": "workspace:*",
    "kysely": "^0.28.0"
  },
  "devDependencies": {
    "@invect/ui": "workspace:*",
    "@tanstack/react-query": "^5.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.20",
    "@types/react": "18.3.7",
    "@types/react-dom": "18.3.7",
    "better-auth": "^1.5.4",
    "lucide-react": "^0.475.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsdown": "^0.21.1",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@better-auth/api-key": ">=1.0.0",
    "@invect/ui": ">=0.0.8",
    "@tanstack/react-query": ">=5.0.0",
    "better-auth": ">=1.0.0",
    "better-sqlite3": ">=9.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-router": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@better-auth/api-key": {
      "optional": true
    },
    "better-auth": {
      "optional": false
    },
    "better-sqlite3": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-router": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "@invect/ui": {
      "optional": true
    }
  }
}
