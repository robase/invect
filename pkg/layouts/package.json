{
  "name": "@invect/layouts",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared layout utilities for Invect graph positioning",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm run build",
    "build:watch": "tsdown --watch",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "echo \"No tests configured\""
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.5",
    "elkjs": "^0.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "tsdown": "^0.21.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0"
  },
  "keywords": [
    "invect",
    "layout",
    "dagre",
    "graph"
  ],
  "author": "robase",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robase/invect.git",
    "directory": "pkg/layouts"
  },
  "bugs": {
    "url": "https://github.com/robase/invect/issues"
  },
  "homepage": "https://invect.dev",
  "publishConfig": {
    "access": "public"
  }
}
