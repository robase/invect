{
  "name": "@invect/core",
  "version": "0.0.11",
  "description": "Framework-agnostic core package for Invect workflow execution engine",
  "keywords": [
    "automation",
    "core",
    "framework-agnostic",
    "invect",
    "workflow"
  ],
  "homepage": "https://invect.dev",
  "bugs": {
    "url": "https://github.com/robase/invect/issues"
  },
  "license": "MIT",
  "author": "robase <team@invect.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/robase/invect.git",
    "directory": "pkg/core"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.frontend.d.ts",
      "import": "./dist/types.frontend.js",
      "require": "./dist/types.frontend.cjs"
    },
    "./drizzle/sqlite": {
      "types": "./dist/database/schema-sqlite.d.ts",
      "import": "./dist/database/schema-sqlite.js",
      "require": "./dist/database/schema-sqlite.cjs"
    },
    "./drizzle/postgres": {
      "types": "./dist/database/schema-postgres.d.ts",
      "import": "./dist/database/schema-postgres.js",
      "require": "./dist/database/schema-postgres.cjs"
    },
    "./drizzle/mysql": {
      "types": "./dist/database/schema-mysql.d.ts",
      "import": "./dist/database/schema-mysql.js",
      "require": "./dist/database/schema-mysql.cjs"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js",
      "require": "./dist/sdk/index.cjs"
    },
    "./actions": {
      "types": "./dist/actions/index.d.ts",
      "import": "./dist/actions/index.js",
      "require": "./dist/actions/index.cjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "lint": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "tsx tests/e2e/run.ts",
    "test:run-all": "tsx tests/run-tests.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "@invect/action-kit": "workspace:*",
    "@invect/actions": "workspace:*",
    "@invect/layouts": "workspace:*",
    "@secure-exec/core": "^0.1.0",
    "@secure-exec/node": "^0.1.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "kysely": "^0.28.14",
    "nanoid": "^5.0.9",
    "openai": "^5.11.0",
    "quickjs-emscripten": "^0.32.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.4",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.4.1",
    "tsdown": "^0.21.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "typescript": ">=4.9.0"
  },
  "optionalDependencies": {
    "@libsql/client": "^0.17.2",
    "@neondatabase/serverless": "^1.0.0",
    "better-sqlite3": "^12.0.0",
    "mysql2": "^3.14.2",
    "pg": "^8.16.0",
    "postgres": "^3.4.7"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
