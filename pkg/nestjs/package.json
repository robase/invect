{
  "name": "@invect/nestjs",
  "version": "0.0.8",
  "private": false,
  "description": "A NestJS module for executing Invect workflows with batch processing capabilities",
  "keywords": [
    "ai",
    "anthropic",
    "batch-processing",
    "invect",
    "nestjs",
    "openai",
    "workflow"
  ],
  "homepage": "https://invect.dev",
  "bugs": {
    "url": "https://github.com/robase/invect/issues"
  },
  "license": "MIT",
  "author": "robase <team@invect.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/robase/invect.git",
    "directory": "pkg/nestjs"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts && tsc --emitDeclarationOnly --outDir dist",
    "build:nest": "nest build",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --fix",
    "test": "echo \"No tests configured\"",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:debug": "vitest --inspect-brk",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:push": "drizzle-kit push",
    "drizzle:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@invect/core": "workspace:*",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.18",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.3",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.12.11",
    "@types/express": "^5.0.3",
    "@types/json-logic-js": "^2.0.8",
    "@types/node": "^24.0.13",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "drizzle-kit": "^0.31.4",
    "msw": "^2.10.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.3",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsdown": "^0.21.1",
    "typescript": "^5.8.3",
    "unplugin-swc": "^1.5.5",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
