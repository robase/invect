{
  "name": "@invect/express",
  "version": "0.0.11",
  "description": "Express.js integration package for Invect Core",
  "keywords": [
    "api",
    "automation",
    "express",
    "invect",
    "workflow"
  ],
  "homepage": "https://invect.dev",
  "bugs": {
    "url": "https://github.com/robase/invect/issues"
  },
  "license": "MIT",
  "author": "robase <team@invect.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/robase/invect.git",
    "directory": "pkg/express"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js",
      "require": "./dist/router/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:w": "tsdown --watch",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --fix",
    "test": "echo \"No tests configured\"",
    "test:watch": "echo \"No tests configured\"",
    "test:coverage": "echo \"No tests configured\""
  },
  "dependencies": {
    "@invect/core": "workspace:*",
    "cors": "^2.8.5",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.20",
    "@types/supertest": "^6.0.2",
    "supertest": "^6.3.4",
    "tsdown": "^0.21.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "express": "^5.0.0"
  }
}
