{
  "name": "@invect/cli",
  "version": "0.0.9",
  "description": "CLI for managing Invect database schemas, migrations, and project setup",
  "keywords": [
    "cli",
    "drizzle",
    "invect",
    "migration",
    "workflow"
  ],
  "homepage": "https://invect.dev",
  "bugs": {
    "url": "https://github.com/robase/invect/issues"
  },
  "license": "MIT",
  "author": "robase <team@invect.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/robase/invect.git",
    "directory": "pkg/cli"
  },
  "bin": {
    "invect-cli": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/api.ts --format esm --clean",
    "dev": "tsup src/index.ts src/api.ts --format esm --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@invect/core": "workspace:*",
    "@mrleebo/prisma-ast": "^0.14.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "jiti": "^2.4.2",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^4.1.4"
  },
  "optionalDependencies": {
    "@invect/mcp": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
