{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "paths": {
      "src/*": ["pkg/core/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "pkg",
    "examples",
    "docs",
    "playwright",
    "playwright-report",
    "test-results",
    "scripts",
    "coverage",
    ".next",
    ".react-router",
    "drizzle",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriority",
    "excludeDirectories": [
      "**/.git",
      "**/.next",
      "**/.react-router",
      "**/coverage",
      "**/dist",
      "**/drizzle",
      "**/node_modules",
      "**/playwright-report",
      "**/test-results"
    ]
  }
}
