{
  "name": "invect-webview-wasm-probe",
  "displayName": "Invect WASM Probe",
  "version": "0.0.1",
  "private": true,
  "description": "Throwaway VSCode extension to verify QuickJS WASM executes inside a webview under strict CSP. Part of Invect VSCode Extension Phase 0 Lane L3.",
  "categories": [
    "Other"
  ],
  "publisher": "invect-internal",
  "main": "./dist/extension.js",
  "scripts": {
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "build:webview": "esbuild webview/main.ts --bundle --outfile=dist/webview/main.js --format=iife --platform=browser --target=es2022 --loader:.wasm=base64",
    "build": "pnpm run build:extension && pnpm run build:webview",
    "watch:extension": "npm run build:extension -- --watch",
    "watch:webview": "npm run build:webview -- --watch"
  },
  "dependencies": {
    "quickjs-emscripten": "^0.29.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "probe.run",
        "title": "Invect Probe: Run QuickJS WASM in Webview"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "engines": {
    "vscode": "^1.85.0"
  }
}
