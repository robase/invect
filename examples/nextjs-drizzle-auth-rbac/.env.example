# Acme Dashboard — Environment Variables
#
# Copy to .env and fill in the values.

# PostgreSQL connection string (run `docker compose up -d` first)
DATABASE_URL=postgresql://acme:acme@localhost:5432/acme_dashboard

# better-auth secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# Initial admin user credentials used by lib/invect.ts
# via authentication({ globalAdmins: [...] }).
# The admin can then create additional users from the Invect UI.
INVECT_ADMIN_EMAIL=admin@acme.com
INVECT_ADMIN_PASSWORD=admin1234

# Invect encryption key for credentials (generate with: npx invect-cli secret)
INVECT_ENCRYPTION_KEY=
