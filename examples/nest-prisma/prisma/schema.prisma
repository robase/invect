// Acme SaaS — Prisma Schema
//
// This is a typical multi-tenant SaaS application schema.
// Invect tables are NOT included here — they will be added
// via `npx invect-cli generate --adapter prisma` during setup.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant Organisation ───────────────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members  Member[]
  projects Project[]

  @@map("organizations")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

// ─── Users & Membership ──────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships Member[]
  apiKeys     ApiKey[]

  @@map("users")
}

model Member {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           Role     @default(MEMBER)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("members")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ─── Projects ────────────────────────────────────────────────────

model Project {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apiKeys      ApiKey[]

  @@map("projects")
}

// ─── API Keys ────────────────────────────────────────────────────

model ApiKey {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  projectId String    @map("project_id")
  name      String
  keyHash   String    @unique @map("key_hash")
  prefix    String
  lastUsed  DateTime? @map("last_used")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Credentials {
  id            String    @id @default(uuid())
  name          String
  type          String
  authType      String    @map("auth_type")
  config        Json
  description   String?
  isActive      Boolean   @default(true) @map("is_active")
  workspaceId   String?   @map("workspace_id")
  isShared      Boolean   @default(false) @map("is_shared")
  metadata      Json?
  lastUsedAt    DateTime? @map("last_used_at") @db.Timestamptz(3)
  expiresAt     DateTime? @map("expires_at") @db.Timestamptz(3)
  webhookPath   String?   @map("webhook_path")
  webhookSecret String?   @map("webhook_secret")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([webhookPath])
}

model Flows {
  id                String         @id
  name              String
  description       String?
  tags              Json?
  isActive          Boolean        @default(true) @map("is_active")
  liveVersionNumber Int?           @map("live_version_number")
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  flowTriggers      FlowTriggers[]
  flowVersions      FlowVersions[]
  chatMessages      ChatMessages[]
  flowRuns          FlowRuns[]
}

model FlowTriggers {
  id              String    @id @default(uuid())
  flowId          String    @map("flow_id")
  nodeId          String    @map("node_id")
  type            String
  isEnabled       Boolean   @default(true) @map("is_enabled")
  webhookPath     String?   @map("webhook_path")
  webhookSecret   String?   @map("webhook_secret")
  cronExpression  String?   @map("cron_expression")
  cronTimezone    String?   @map("cron_timezone")
  lastTriggeredAt DateTime? @map("last_triggered_at") @db.Timestamptz(3)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  flow            Flows     @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([webhookPath])
  @@map("flow_triggers")
}

model FlowVersions {
  flowId           String   @map("flow_id")
  version          Int
  invectDefinition Json     @map("invect_definition")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  createdBy        String?  @map("created_by")
  flow             Flows    @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@id([version, flowId])
  @@map("flow_versions")
}

model ChatMessages {
  id        String   @id @default(uuid())
  flowId    String   @map("flow_id")
  role      String
  content   String   @default("")
  toolMeta  Json?    @map("tool_meta")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  flow      Flows    @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model FlowRuns {
  id              String         @id @default(uuid())
  flowId          String         @map("flow_id")
  flowVersion     Int            @map("flow_version")
  status          String         @default("PENDING")
  inputs          Json
  outputs         Json?
  error           String?
  startedAt       DateTime       @default(now()) @map("started_at") @db.Timestamptz(3)
  completedAt     DateTime?      @map("completed_at") @db.Timestamptz(3)
  duration        Int?
  createdBy       String?        @map("created_by")
  triggerType     String?        @map("trigger_type")
  triggerId       String?        @map("trigger_id")
  triggerNodeId   String?        @map("trigger_node_id")
  triggerData     Json?          @map("trigger_data")
  lastHeartbeatAt DateTime?      @map("last_heartbeat_at") @db.Timestamptz(3)
  flow            Flows          @relation(fields: [flowId], references: [id], onDelete: Cascade)
  actionTraces    ActionTraces[]
  batchJobs       BatchJobs[]

  @@map("flow_executions")
}

model ActionTraces {
  id                    String        @id @default(uuid())
  flowRunId             String        @map("flow_run_id")
  parentNodeExecutionId String?       @map("parent_node_execution_id")
  nodeId                String?       @map("node_id")
  nodeType              String?       @map("node_type")
  toolId                String?       @map("tool_id")
  toolName              String?       @map("tool_name")
  iteration             Int?
  status                String        @default("PENDING")
  inputs                Json
  outputs               Json?
  error                 String?
  startedAt             DateTime      @default(now()) @map("started_at") @db.Timestamptz(3)
  completedAt           DateTime?     @map("completed_at") @db.Timestamptz(3)
  duration              Int?
  retryCount            Int           @default(0) @map("retry_count")
  flowRun               FlowRuns      @relation(fields: [flowRunId], references: [id], onDelete: Cascade)
  parentNodeExecution   ActionTraces? @relation(fields: [parentNodeExecutionId], references: [id], onDelete: Cascade)

  @@map("action_traces")
}

model BatchJobs {
  id           String    @id @default(uuid())
  flowRunId    String    @map("flow_run_id")
  nodeId       String    @map("node_id")
  provider     String
  batchId      String?   @map("batch_id")
  status       String    @default("SUBMITTED")
  requestData  Json      @map("request_data")
  responseData Json?     @map("response_data")
  error        String?
  submittedAt  DateTime  @default(now()) @map("submitted_at") @db.Timestamptz(3)
  completedAt  DateTime? @map("completed_at") @db.Timestamptz(3)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  flowRun      FlowRuns  @relation(fields: [flowRunId], references: [id], onDelete: Cascade)

  @@map("batch_jobs")
}
