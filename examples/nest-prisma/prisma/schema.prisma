// Acme SaaS — Prisma Schema
//
// This is a typical multi-tenant SaaS application schema.
// Invect tables are NOT included here — they will be added
// via `npx invect-cli generate --adapter prisma` during setup.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant Organisation ───────────────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members  Member[]
  projects Project[]

  @@map("organizations")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

// ─── Users & Membership ──────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships Member[]
  apiKeys     ApiKey[]

  @@map("users")
}

model Member {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           Role     @default(MEMBER)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("members")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ─── Projects ────────────────────────────────────────────────────

model Project {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apiKeys      ApiKey[]

  @@map("projects")
}

// ─── API Keys ────────────────────────────────────────────────────

model ApiKey {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  projectId String    @map("project_id")
  name      String
  keyHash   String    @unique @map("key_hash")
  prefix    String
  lastUsed  DateTime? @map("last_used")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

