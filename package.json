{
  "name": "invect",
  "version": "0.0.1",
  "private": true,
  "description": "Complete workflow management system with React frontend and NestJS backend",
  "keywords": [
    "Invect",
    "ai",
    "backend",
    "batch-processing",
    "components",
    "frontend",
    "invect",
    "nestjs",
    "react",
    "typescript",
    "workflow"
  ],
  "homepage": "https://invect.dev",
  "bugs": {
    "url": "https://github.com/robase/invect/issues"
  },
  "license": "MIT",
  "author": "robase <team@invect.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/robase/invect.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm --filter '@invect/*' run build",
    "link:all": "pnpm build && pnpm --filter '@invect/*' exec npm link",
    "build:core": "pnpm --filter '@invect/core' run build",
    "build:ui": "pnpm --filter '@invect/ui' run build",
    "build:nestjs": "pnpm --filter '@invect/nestjs' run build",
    "build:express": "pnpm --filter '@invect/express' run build",
    "build:nextjs": "pnpm --filter '@invect/nextjs' run build",
    "dev": "bash scripts/dev.sh",
    "dev:packages": "pnpm --filter '@invect/*' --parallel run dev",
    "dev:express-example": "pnpm --filter '...invect-express-simple' --parallel run dev",
    "dev:vite-example": "pnpm --filter '...flow-executor' --parallel run dev",
    "dev:all": "pnpm --filter '@invect/*' --parallel run dev",
    "dev:fullstack": "bash scripts/dev-fullstack.sh",
    "dev:next": "bash scripts/dev-next.sh",
    "dev:nest": "bash scripts/dev-nest.sh",
    "dev:watch-all": "pnpm --filter '...invect-express-simple' --filter '...flow-executor' --parallel run dev",
    "test": "pnpm --filter '@invect/core' run test:unit && pnpm --filter '@invect/cli' --filter '@invect/user-auth' --filter '@invect/version-control' run test",
    "test:int": "pnpm --filter '@invect/core' run test:integration",
    "test:all": "pnpm -r --filter './pkg/**' run test",
    "test:e2e": "pnpm --filter '@invect/core' run test:e2e",
    "test:pw": "node scripts/run-playwright-with-port-check.mjs --project api --project frontend --project e2e --project critical-paths",
    "test:pw:force-kill": "node scripts/run-playwright-with-port-check.mjs --force-kill-ports --project api --project frontend --project e2e --project critical-paths",
    "test:pw:ui": "node scripts/run-playwright-with-port-check.mjs --ui",
    "test:pw:headed": "node scripts/run-playwright-with-port-check.mjs --headed",
    "ux:capture": "npx playwright test --config playwright/playwright.config.ts --project visual-audit",
    "ux:analyze": "npx tsx playwright/visual-audit/analyze.ts",
    "ux:audit": "pnpm ux:capture && pnpm ux:analyze",
    "setup:credentials": "bash scripts/setup-credentials.sh",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "rm -rf dist && pnpm --filter '@invect/*' run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && pnpm publish -r --access public --no-git-checks"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.56.0",
    "@invect/cli": "link:pkg/cli",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.0.0",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@types/pg": "^8.15.4",
    "@xyflow/react": "^12.8.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "json-logic-js": "^2.0.5",
    "lucide-react": "^0.525.0",
    "mysql2": "^3.14.2",
    "openai": "^5.9.0",
    "pg": "^8.16.3",
    "prisma": "^6.11.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.13",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^4.0.1",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "eslint-plugin-security": "^4.0.0",
    "express": "^5.2.1",
    "knip": "^6.3.0",
    "msw": "^2.11.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "rollup": "^4.14.0",
    "tsdown": "^0.21.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.7",
      "@types/react-dom": "18.3.7",
      "picomatch": ">=4.0.4",
      "defu": ">=6.1.5",
      "tar": ">=7.5.11",
      "handlebars": ">=4.7.9",
      "flatted": ">=3.4.2",
      "esbuild": ">=0.25.0",
      "vite": ">=8.0.5",
      "lodash": ">=4.18.0",
      "lodash-es": ">=4.18.0",
      "brace-expansion": ">=2.0.3",
      "effect": ">=3.20.0",
      "path-to-regexp": ">=8.4.0",
      "hono": ">=4.12.12"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "@tailwindcss/oxide",
      "better-sqlite3",
      "esbuild",
      "isolated-vm",
      "msw",
      "prisma",
      "sharp",
      "sqlite3",
      "unrs-resolver"
    ]
  }
}
